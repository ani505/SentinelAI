# Copy this file to .env and fill in your values

# Sepolia RPC URL from Infura/Alchemy (leave blank to run without blockchain)
SEPOLIA_RPC_URL=

# Deployed contract address on Sepolia
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Your Ethereum wallet private key (without 0x prefix)
PRIVATE_KEY=

# API keys for the REST API - comma separated
# Default matches the frontend demo key - change in production!
API_KEYS=demo_key_12345
